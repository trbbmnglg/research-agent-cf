{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "research-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  // LangGraph.js / LangChain.js need Node built-ins (async_hooks, buffer, …)
  "compatibility_flags": ["nodejs_compat"],
  // Custom domain — Cloudflare auto-creates the DNS record + TLS cert on deploy
  // (requires robertbumanglagjr.com to be a zone on this Cloudflare account).
  "routes": [
    { "pattern": "research-agent.robertbumanglagjr.com", "custom_domain": true }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    // Only run the Worker for API calls; everything else is served as a static file.
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  // Smart Placement routes the Worker to the Cloudflare region closest to its
  // upstream dependencies (Anthropic, Tavily, OpenAI) rather than to the user.
  // This is critical — without it the Worker runs from APAC which is geo-blocked
  // by both Anthropic and OpenAI's images API.
  "placement": {
    "mode": "smart"
  },
  // Daily auto-run at 07:00 UTC. Test locally: wrangler dev --test-scheduled
  "triggers": {
    "crons": ["0 7 * * *"]
  },
  // Create namespaces first:
  //   wrangler kv namespace create RESEARCH_KV          → paste prod id below
  //   wrangler kv namespace create RESEARCH_KV --preview → paste preview_id below
  "kv_namespaces": [
    {
      "binding": "RESEARCH_KV",
      "id": "201a43ccae1f436da2fc23ab6fd83688",
      "preview_id": "077df9697ed34350bd1c12f3fa29ea7f"
    }
  ]
  ,
  // Run: wrangler d1 migrations apply research-agent-db --remote
  "d1_databases": [
    {
      "binding": "RESEARCH_DB",
      "database_name": "research-agent-db",
      "database_id": "da3be8bc-7306-415a-8b3f-e95351bf18d1"
    }
  ]
  // Workers AI binding — used for thumbnail generation (FLUX schnell).
  // Free tier: 10,000 neurons/day; FLUX schnell ≈ 150 neurons/image.
  ,
  "ai": { "binding": "AI" }
  // Plain vars — edit here, override in .dev.vars for local dev.
  // Not sensitive; API keys go via `wrangler secret put` instead.
  ,
  "vars": {
    "NOTIFY_EMAIL": "web.rbbjr@gmail.com",
    "NOTIFY_FROM":  "newsagent@robertbumanglagjr.com",
    // CF AI Gateway base — routes OpenAI calls through Cloudflare's network.
    // Create the gateway at dash.cloudflare.com → AI Gateway → "research-agent"
    // then paste: https://gateway.ai.cloudflare.com/v1/<account_id>/research-agent
    "CF_AI_GATEWAY": "https://gateway.ai.cloudflare.com/v1/7f817fd99a51e8d8de80bab50f356220/research-agent"
  }
  // Secrets (wrangler secret put, or .dev.vars locally):
  //   ANTHROPIC_API_KEY   – Anthropic key
  //   TAVILY_API_KEY      – Tavily key
  //   MANUAL_PASSWORD     – password that guards the Run Now button
  //   LANGCHAIN_API_KEY   – (optional) LangSmith tracing key — smith.langchain.com
  //   LANGCHAIN_PROJECT   – (optional) LangSmith project name, defaults to "research-agent-cf"
  //   RESEND_API_KEY      – (optional) Resend key for daily email delivery — resend.com
  //   OPENAI_API_KEY      – (optional) OpenAI key for gpt-image-2 thumbnail generation — platform.openai.com
  //   CF_AI_GATEWAY_KEY   – (optional) Gateway API key when "Require Authentication" is on in AI Gateway settings
}
