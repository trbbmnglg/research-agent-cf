{
  "name": "research-agent-cf",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Self-correcting AI news research agent — LangGraph.js on Cloudflare Workers",
  "scripts": {
    "build-prompts": "node scripts/build-prompts.mjs",
    "dev": "npm run build-prompts && wrangler dev",
    "deploy": "npm run build-prompts && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.4.1",
    "@langchain/openai": "^1.4.7"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "js-yaml": "^4.2.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}
